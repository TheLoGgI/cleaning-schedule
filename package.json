{
  "name": "cleaning-schedule",
  "version": "2.0.0",
  "private": true,
  "homepage": ".",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 8888",
    "build": "next build",
    "postbuild": "node scripts/copy-standalone-assets.js",
    "start": "next start",
    "lint": "next lint",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "electron:dev": "next build && node scripts/copy-standalone-assets.js && electron .",
    "electron:build": "next build && npx @electron/rebuild -m .next/standalone -w better-sqlite3 && electron-builder"
  },
  "build": {
    "appId": "com.cleaningschedule.app",
    "productName": "cleaning-schedule",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**",
      "drizzle/**"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app/.next/standalone"
      },
      {
        "from": "public",
        "to": "app/public"
      },
      {
        "from": "drizzle",
        "to": "app/drizzle"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@react-email/button": "0.2.1",
    "@react-email/components": "1.0.11",
    "@react-email/html": "0.0.12",
    "@react-email/render": "2.0.5",
    "@tailwindcss/forms": "^0.5.11",
    "@vercel/analytics": "^2.0.1",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.2",
    "react": "^19",
    "react-dom": "^19",
    "react-email": "5.2.10",
    "resend": "^6.10.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "@electron/rebuild": "^3.6.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "daisyui": "^5.5.19",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10",
    "eslint-config-next": "16.2.2",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "electron",
      "electron-winstaller",
      "fast-folder-size"
    ],
    "ignoredBuiltDependencies": [
      "sharp"
    ]
  }
}
